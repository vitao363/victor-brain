# ─────────────────────────────────────────
# VICTOR BRAIN v2 — variáveis de ambiente
# Copie este arquivo para .env e preencha
# NÃO suba o .env pro GitHub!
# ─────────────────────────────────────────

# Token do seu bot (gerado pelo @BotFather)
TELEGRAM_TOKEN=7xxxxxxxxx:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chave da API da Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL do projeto Supabase (Settings → API → Project URL)
SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co

# Chave anon/public do Supabase (Settings → API → anon public)
SUPABASE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Seu Chat ID do Telegram (manda /start pro bot e ele te diz)
ALLOWED_CHAT_ID=000000000

# Modelo Claude (opcional — default: claude-sonnet-4-5-20250514)
# Opções: claude-sonnet-4-5-20250514, claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-sonnet-4-5-20250514
